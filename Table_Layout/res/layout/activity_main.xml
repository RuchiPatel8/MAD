    <!-- Header Row -->
    <TableRow>
        <TextView android:text="Name" android:textStyle="bold" android:padding="8dp"/>
        <TextView android:text="Consumer No" android:textStyle="bold" android:padding="8dp"/>
        <TextView android:text="Units" android:textStyle="bold" android:padding="8dp"/>
        <TextView android:text="Bill (₹)" android:textStyle="bold" android:padding="8dp"/>
    </TableRow>

    <!-- Row 1 -->
    <TableRow>
