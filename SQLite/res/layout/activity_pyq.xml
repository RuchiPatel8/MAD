<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    tools:context=".PyqActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/dance_primary"
        app:title="Search PYQs"
        app:titleTextColor="@color/white" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:text="Select a level to search for previous year question papers on Google."
        android:textColor="@color/text_secondary"
        android:textSize="16sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Same levels buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPyq1"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:text="@string/level_prarambhik"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_search" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPyq2"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:text="@string/level_praveshika_pratham"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_search" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPyq3"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:text="@string/level_praveshika_poorna"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_search" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPyq4"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:text="@string/level_madhyama_pratham"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_search" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPyq5"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:text="@string/level_madhyama_poorna"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_search" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPyq6"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:text="@string/level_visharada_pratham"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_search" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPyq7"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="32dp"
                android:text="@string/level_visharada_poorna"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_search" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRatePyq"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Rate this section"
        android:textColor="@color/dance_primary" />

</LinearLayout>
